# ─── Environment ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Server Configuration ───────────────────────────────────────────────────────
PORT=10000
HOST=0.0.0.0
CORS_ORIGIN=*
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_PAYLOAD_SIZE=10485760

# ─── Logging Configuration ─────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty
ENABLE_STACK_TRACE=true

# ─── LLM API Keys ────────────────────────────────────────────────────────────
CEREBRAS_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_AI_API_KEY=
HF_API_KEY=
JINA_API_KEY=

# ─── LLM Model Config ─────────────────────────────────────────────────────────
CEREBRAS_MODEL=GLM-4-9B
CEREBRAS_TIMEOUT=10000

GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=15000

GOOGLE_MODEL=gemini-2.5-flash-lite
GOOGLE_TIMEOUT=20000

OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_TIMEOUT=20000

TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free
TOGETHER_TIMEOUT=20000

HF_MODEL=meta-llama/Llama-3.3-70B-Instruct
HF_TIMEOUT=30000

# LLM Fallback Configuration
LLM_ENABLE_FALLBACK=true
LLM_FALLBACK_RETRY_ATTEMPTS=3
LLM_PROVIDER_COOLDOWN_MS=60000

# ─── Voice Configuration ────────────────────────────────────────────────────────
SARVAM_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=
DEFAULT_VOICE=en-US
VOICE_ENABLE_FALLBACK=true

# ─── Cloud Service URLs ───────────────────────────────────────────────────────
TILLU_MEMORY_URL=https://tillu-memory.vercel.app
TILLU_SEARCH_URL=https://tillu-smart-search.vercel.app
TILLU_VOICE_URL=https://tillu-voice.vercel.app
TILLU_SEE_URL=https://tillu-see.vercel.app
TILLU_NEWS_WEATHER_URL=https://tillu-news-weather.vercel.app

SERVICE_TIMEOUT=30000
SERVICE_RETRIES=3

# ─── User Profile ──────────────────────────────────────────────────────────────
TILLU_USER_ID=heoster
TILLU_USER_NAME=Harsh
TILLU_NICKNAME=Heoster
TILLU_TIMEZONE=Asia/Kolkata
TILLU_LANGUAGE=hi-en
TILLU_LOCATION=Rampur Khatauli, Muzaffarnagar, UP, India
TILLU_SCHOOL=Maples Academy, Khatauli
TILLU_CLASS=12

# ─── Dream Loop Configuration ─────────────────────────────────────────────────
DREAM_LOOP_ENABLED=true
DREAM_LOOP_INTERVAL_HOURS=1
MORNING_BRIEFING_TIME=05:30
CONSOLIDATION_TIME=23:00

ENABLE_MEMORY_CONSOLIDATION=true
ENABLE_MORNING_BRIEFING=true
ENABLE_WORLD_MONITOR=true
ENABLE_CALENDAR_CHECK=true
ENABLE_SELF_REVIEW=true

# ─── WebSocket Configuration ───────────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30000
WS_CLIENT_TIMEOUT=60000
WS_MAX_CONNECTIONS=100
WS_ENABLE_COMPRESSION=true

# ─── Security Configuration ────────────────────────────────────────────────────
ENABLE_RATE_LIMIT=true
ENABLE_CORS=true
ENABLE_HELMET=false
ENABLE_REQUEST_LOGGING=true
API_KEY=

# ─── Monitoring Configuration ───────────────────────────────────────────────────
ENABLE_METRICS=false
ENABLE_HEALTH_CHECK=true
METRICS_PATH=/metrics
HEALTH_CHECK_PATH=/health

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_SKILLS=true
ENABLE_SELF_EVOLUTION=true
ENABLE_CALENDAR=true
ENABLE_RELATIONSHIP_TRACKING=true
