# ─── LLM API Keys ────────────────────────────────────────────────────────────
CEREBRAS_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_AI_API_KEY=
HF_API_KEY=

# ─── LLM Model Overrides (optional — defaults shown) ─────────────────────────
# Cerebras available models: llama-3.3-70b | llama-4-scout-17b-16e-instruct | llama3.1-8b
CEREBRAS_MODEL=llama-3.3-70b

# Groq available models: llama-3.3-70b-versatile | llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# Google available models: gemini-2.5-flash-lite | gemini-2.5-flash | gemini-2.5-pro
GOOGLE_MODEL=gemini-2.5-flash-lite

# OpenRouter free models: meta-llama/llama-3.3-70b-instruct:free | mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# HuggingFace models: meta-llama/Llama-3.3-70B-Instruct
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ─── Voice ────────────────────────────────────────────────────────────────────
SARVAM_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# ─── Cloud Service URLs ───────────────────────────────────────────────────────
TILLU_MEMORY_URL=https://tillu-memory.vercel.app
TILLU_SEARCH_URL=https://tillu-smart-search.vercel.app
TILLU_VOICE_URL=https://tillu-voice.vercel.app
TILLU_SEE_URL=https://tillu-see.vercel.app

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=development
