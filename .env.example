# ─── LLM API Keys ────────────────────────────────────────────────────────────
CEREBRAS_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_AI_API_KEY=
HF_API_KEY=

# ─── LLM Model Config ─────────────────────────────────────────────────────────
# Cerebras — only free model: GLM-4-9B (via OSSZ.ai on Cerebras)
# Paid models (llama-3.3-70b, llama-4-scout-17b-16e-instruct) require paid plan
CEREBRAS_MODEL=GLM-4-9B

# Groq — primary planner + classifier fallback
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — primary writer (get key at aistudio.google.com)
GOOGLE_MODEL=gemini-2.5-flash-lite

# OpenRouter — free tier fallback
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Together AI — free tier models (quality fallback for writer + planner)
# Free models: Llama-3.3-70B-Turbo-Free | DeepSeek-R1-Distill-Llama-70B-Free | Qwen2.5-72B-Free
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# HuggingFace — last resort
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ─── Voice ────────────────────────────────────────────────────────────────────
SARVAM_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# ─── Cloud Service URLs ───────────────────────────────────────────────────────
TILLU_MEMORY_URL=https://tillu-memory.vercel.app
TILLU_SEARCH_URL=https://tillu-smart-search.vercel.app
TILLU_VOICE_URL=https://tillu-voice.vercel.app
TILLU_SEE_URL=https://tillu-see.vercel.app
TILLU_NEWS_WEATHER_URL=https://tillu-news-weather.vercel.app

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=development
